#
# Module variables
#
# * Shared internal variables for module tasks
#

# shellcheck disable=SC2154
{
  # Env / Project / Module environment definition version
  export DEV_ENV_PROJECT_ID='project'
  export DEV_ENV_PROJECT_VERSION='1.0.0'

  # Lib / Project / Command
  export DEV_LIB_PROJECT_BIN="${DEV_PATH_ROOT}/cntbuild"

  # Build / Project / Image list name suffix
  export DEV_BUILD_PROJECT_LIST_PREFIX='DEV_BUILD_PROJECT_CATALOG_'
  # Build / Project / Target
  export DEV_BUILD_PROJECT_PATH_TARGET="${DEV_PATH_BUILD_PREPARE}/${DEV_ENV_PROJECT_ID}"
}

#
# Module parameters
#
# * Use .dev.env file to override values
#

# shellcheck disable=SC2154
{
  # Build / Project / Target
  export DEV_BUILD_PROJECT_PATH_SOURCE="${DEV_BUILD_PROJECT_PATH_SOURCE:-}"
}
