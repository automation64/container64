export DEV_PROFILE="${1:-}"

function _dev_profile_set_profile() {
  [[ -d "etc/prof/${DEV_PROFILE}" ]] && return 0
  ./bin/dev-profile-create "$DEV_PROFILE"
}

function _dev_profile_set_load() {
  source ./bin/dev-set ||
    { echo 'dev-profile-set:Error: unable to load dev environment' 2>&1 && return 1; }
}

function _dev_profile_set_initialize() {
  [[ "${BASH_SOURCE[0]}" == "${0}" ]] &&
    echo 'dev-profile-set:Error: invalid execution method. Use the following command line to run this script: source ./bin/dev-profile-set.' 2>&1 &&
    return 1
  [[ -z "$DEV_PROFILE" ]] &&
    echo 'dev-profile-set:Error: missing profile name.' 2>&1 &&
    return 1
  [[ "$DEV_PROFILE" == 'none' ]] &&
    echo 'dev-profile-set:Error: invalid profile name (none).' 2>&1 &&
    return 1
  return 0
}

# Warning: keep the namespace to avoid source conflicts
_dev_profile_set_initialize &&
  _dev_profile_set_profile &&
  _dev_profile_set_load &&
  unset _dev_profile_set_initialize &&
  unset _dev_profile_set_profile &&
  unset _dev_profile_set_load
